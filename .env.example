# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# For local development, copy this file to .env.local and fill in your key.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL (optional): main matching model for stage-2 analysis.
# Default: gemini-2.5-flash (works on free tier).
# If your key has billing enabled, set to gemini-3.1-pro-preview for best quality
# (Pro models have ZERO free-tier quota and will auto-fallback to Flash otherwise).
# GEMINI_MODEL="gemini-2.5-flash"

# GEMINI_CLASSIFIER_MODEL (optional): fast model for stage-1 candidate selection.
# Default: gemini-3.1-flash-lite
# GEMINI_CLASSIFIER_MODEL="gemini-3.1-flash-lite"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
