# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# For local development, copy this file to .env.local and fill in your key.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL (optional): main matching model for stage-2 analysis.
# Default: gemini-3.1-flash-lite (fastest + most reliable on free tier, ~3s;
# quality is safeguarded by decode tables + catalog validation).
# Paid accounts can set gemini-2.5-flash or gemini-3.1-pro-preview for smarter
# reasoning on complex assemblies (Pro models have ZERO free-tier quota).
# GEMINI_MODEL="gemini-3.1-flash-lite"

# GEMINI_CLASSIFIER_MODEL (optional): fast model for stage-1 candidate selection.
# Default: gemini-3.1-flash-lite
# GEMINI_CLASSIFIER_MODEL="gemini-3.1-flash-lite"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ---- 團隊共用雲端 (選填) ----
# 設定後「確認清單、對手知識庫、自我學習修正」會全公司共用、跨裝置同步。
# 不設定則自動退回各自瀏覽器的 localStorage (app 照常運作)。
#
# 做法：在 Vercel 專案 → Storage → 建立 Upstash Redis (或 KV)，
# Vercel 會自動注入以下環境變數，不需手動填：
# KV_REST_API_URL="https://xxx.upstash.io"
# KV_REST_API_TOKEN="xxxxxx"
# (Upstash 原生變數 UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN 亦支援)
#
# 本機開發若想測試共用功能，可改用記憶體後端 (單一程序內有效)：
# LOCAL_MEMORY_STORE=1
